# Copy to .env or .env.local and fill in values.

# --- Public (client) - EXPO_PUBLIC_* is bundled into the app ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_APPWRITE_APP_ID=your_appwrite_project_id
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_DB_ID=your_database_id
EXPO_PUBLIC_APPWRITE_COLLECTION_ID=your_session_collection_id
EXPO_PUBLIC_APPWRITE_PLATFORM=com.anonymous.numal-mindfulness
EXPO_PUBLIC_AGENT_ID=your_elevenlabs_agent_id

# Base URL for this app's API (e.g. /api/conversations).
# Web: can be empty (uses relative URLs). Native: required (e.g. http://localhost:8081 in dev).
EXPO_PUBLIC_API_URL=

# --- Server-only (never use EXPO_PUBLIC_ for secrets) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
